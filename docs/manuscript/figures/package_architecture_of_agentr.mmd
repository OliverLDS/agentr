flowchart TB
    classDef state fill:#edf3fb,stroke:#4a6ea9,stroke-width:2px;
    classDef scaffold fill:#eaf4ee,stroke:#3f7559,stroke-width:2px;
    classDef artifact fill:#fbf4df,stroke:#a78622,stroke-width:2px;
    classDef bridge fill:#f6edf8,stroke:#8c5fa8,stroke-width:2px;
    classDef runtime fill:#f5f5f5,stroke:#8b8b8b,stroke-dasharray: 5 4,stroke-width:1.8px;

    subgraph L1[State layer]
        direction LR
        CS[CognitiveState]
        AS[AffectiveState<br/>optional]
        AC[AgentCore]
    end

    subgraph L2[Scaffolding and design layer]
        direction LR
        SC[Scaffolder]
        AGS[AgentSpec]
        SS[SubsystemSpec]
        IA[IntelligentAgent]
    end

    subgraph L3[Reviewable specification layer]
        direction LR
        MS[MemorySpec]
        KS[KnowledgeSpec]
        KG[Graph knowledge]
        DR[DesignReviewSpec]
    end

    subgraph L4[Proposal layer]
        direction LR
        WP[WorkflowProposal]
        WPS[WorkflowProposalState]
        MP[Memory proposals]
        KP[Knowledge proposals]
        GP[Graph proposals]
    end

    subgraph L5[Constrained model bridge]
        direction LR
        BR[Prompt builders<br/>validated JSON actions<br/>manual LLM calls]
    end

    subgraph L6[Persistent design artifacts]
        direction LR
        WF[workflow specs<br/>YAML editable source]
        PA[proposal artifacts]
        AD[approved design artifacts<br/>portable handoff]
        RH[standalone review HTML]
    end

    CS --> AC
    AS --> AC
    AC --> SC
    SC --> AGS
    AGS --> SS
    AGS --> IA
    AGS --> MS
    AGS --> KS
    KS --> KG
    AGS --> DR

    SC --> WP
    WPS --> WP
    SC --> WPS
    MS --> MP
    KS --> KP
    KG --> GP
    DR --> RH

    BR --> SC
    BR --> MP
    BR --> KP
    BR --> GP

    SC --> WF
    WP --> PA
    WPS --> PA
    AGS --> AD
    SS --> AD
    IA --> AD

    subgraph EX[Excluded execution-layer concerns]
        direction TB
        E1[provider-specific LLM clients]
        E2[transport backends]
        E3[execution engines]
        E4[domain-specific runtimes]
    end

    SC -. excluded boundary .-> EX
    IA -. implemented elsewhere .-> EX

    class CS,AS,AC state;
    class SC,AGS,SS,IA scaffold;
    class MS,KS,KG,DR,WP,WPS,MP,KP,GP,WF,PA,AD,RH artifact;
    class BR bridge;
    class E1,E2,E3,E4 runtime;
